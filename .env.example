# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aix_cloud
DB_USER=postgres
DB_PASSWORD=Xiaoyulong1981

# JWT (for internal services)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# API Keys for upstream providers (examples - replace with real keys)
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_API_KEY=xxx
DEEPSEEK_API_KEY=sk-xxx
LKEAP_API_KEY=sk-xxx

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Email Configuration (Nodemailer with QQ Mail)
# Copy these to your .env file and fill in your actual values
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=tomxyl@qq.com
EMAIL_PASS=your_qq_authorization_code_here
EMAIL_FROM_NAME=AIII Cloud

# Verification Code Security Settings
EMAIL_COOLDOWN_SECONDS=60
MAX_VERIFICATION_ATTEMPTS=5
CODE_EXPIRY_MINUTES=5
MAX_CODES_PER_HOUR=60
MAX_CODES_PER_IP_PER_HOUR=60
