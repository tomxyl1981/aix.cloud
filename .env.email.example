# Email Configuration
# Fill in your email settings below

# SMTP Configuration for QQ Mail
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_SECURE=true

# Your QQ email address
EMAIL_USER=tomxyl@qq.com

# Your QQ email authorization code (NOT your QQ password)
# To get this:
# 1. Go to QQ Mail Settings -> Accounts
# 2. Enable "SMTP/IMAP/POP3" service
# 3. Generate an authorization code
EMAIL_PASS=your_authorization_code_here

# Sender name (what recipients will see)
EMAIL_FROM_NAME=AIII Cloud

# Rate Limiting Settings (in seconds)
# Cooldown between code requests for the same email
EMAIL_COOLDOWN_SECONDS=60

# Maximum verification attempts before code expires
MAX_VERIFICATION_ATTEMPTS=5

# Code expiration time (in minutes)
CODE_EXPIRY_MINUTES=5

# Maximum codes sent per hour per email
MAX_CODES_PER_HOUR=3

# Maximum codes sent per hour per IP address
MAX_CODES_PER_IP_PER_HOUR=10
